{
  "manifest_version": 3,
  "name": "PDF.js Chrome Extension Viewer",
  "version": "1.0",
  "description": "Renders PDFs using locally bundled PDF.js",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "web_accessible_resources": [
    {
      "resources": ["pdf.mjs", "pdf.worker.mjs"],

      "matches": ["<all_urls>"]
    }
  ]
}
